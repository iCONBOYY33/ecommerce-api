generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id        String   @id @default(uuid())
  title     String
  price     Float
  image     String
  createdAt DateTime @default(now())

  orderItems OrderItem[]
}


model Order {
  id         String   @id @default(uuid())
  totalPrice Float
  createdAt  DateTime @default(now())

  items      OrderItem[]
}


model OrderItem {
  id        String  @id @default(uuid())
  quantity  Int
  price     Float

  product   Product @relation(fields: [productId], references: [id])
  productId String

  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
}